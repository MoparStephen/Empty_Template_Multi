    39
    40 				;--------------------------------------------------------
    41 				; Get_HATABS_Entry - retrives handler ID from HATABS table
    42 				; takes:
    43 				; A - HATABS offset from ICHID
    44 				; returns:
    45 				; A - letter identificator of the handler
    46 400A			Get_HATABS_Entry
    47 400A 86 8D			stx	XR_Temp
    48 400C AA				tax
    49 400D BD 1A 03			lda	HATABS,x
    50 4010 A6 8D			ldx	XR_Temp
    51 4012 60				rts
    52 					
    53 				;--------------------------------------------------------
    54 				;Find_Matching_IOCB - search for first matching IOCB
    55 				; takes:
    56 				; A - letter identificator of the handler to look for
    57 				; returns:
    58 				; X - relative offset to first free IOCB (IOCB number *16)
    59 				; Y - error code (126 - nonexistent device) if it fails
    60
    61 4013			Find_Matching_IOCB
    62 4013 85 8C			sta	AR_Temp
    63 4015 A2 00			ldx	#0x00
    64 4017 A0 01			ldy	#0x01
    65 4019			Find_Matching_IOCB_l1
    66 4019 BD 40 03			lda	ICHID,x
    67 401C 20 0A 40			jsr	Get_HATABS_Entry
    68 401F C5 8C			cmp	AR_Temp		; compare device ID with the one searched
    69 4021 F0 09			beq	Find_Matching_IOCB_Found
    70 4023 8A				txa
    71 4024 18 69 10			add	#0x10		; add IOCB structure length to x pointer, and try next channel
    72 4027 AA				tax
    73 4028 10 EF			bpl	Find_Matching_IOCB_l1
    74 402A A0 82			ldy	#-126		; if fails, change error code to "NONEXISTENT DEVICE"	
    75 402C			Find_Matching_IOCB_Found
    76 402C 60				rts
    77
    78 				;--------------------------------------------------------
    79 				;Find_First_IOCB - search for first free IOCB
    80 				; returns:
    81 				; X - relative offset to first free IOCB (IOCB number *16)
    82 				; Y - error code (95 - too many channels open) if it fails
    83 				; 
    84 				; This piece of code comes from Polish Atariki page
    85 				; there are no references for its orgins
    86
    87 402D			Find_First_IOCB
    88 402D A2 00			ldx	#0x00		; start with channel #0
    89 402F A0 01			ldy	#0x01		; set the error code to #1 - success
    90 4031			Find_First_IOCB_l1
    91 4031 BD 40 03			lda	ICHID,x		; get the device ID
    92 4034 C9 FF			cmp	#0xff		; if equals to 0xff - channel is not opened
    93 4036 F0 09			beq	Find_First_IOCB_found
    94 4038 8A				txa
    95 4039 18 69 10			add	#0x10		; add IOCB structure length to x pointer, and try next channel
    96 403C AA				tax
    97 403D 10 F2			bpl	Find_First_IOCB_l1
    98 403F A0 A1			ldy	#-95       	;if fails, change error code to "TOO MANY CHANNELS OPEN"	
    99 4041			Find_First_IOCB_found
   100 4041 60				rts
   101
