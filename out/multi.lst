   103 				; PutLine - puts line of text pointed by TextPtr
   104 				; line should end with ENTER (0x9b)
   105 4042			PutLine
   106 				;	brk
   107 4042 AE 00 40			ldx	Console_IOCB
   108 4045 E0 FF			cpx	#255
   109 4047 D0 10			bne	PutLine_IOCB_Open
   110 4049 A9 45			lda	#'E'
   111 404B 20 13 40			jsr	Find_Matching_IOCB
   112 404E C0 01			cpy	#1
   113 4050 F0 07			beq	PutLine_IOCB_Found
   114 4052 A9 45			lda	#'E'		; open through console handler
   115 4054 A0 00			ldy	#0		; Mode 0 - standard text console
   116 4056 20 73 40			jsr	SetGraphicsMode
   117 4059			PutLine_IOCB_Open
   118 4059			PutLine_IOCB_Found
   119 4059 A9 09			lda	#CIO_puttext
   120 405B 9D 42 03			sta	iccmd,x
   121 405E A9 FF			lda	#255
   122 4060 9D 48 03			sta	ICBLL,x
   123 4063 AD 36 41			lda	TextPtr
   124 4066 9D 44 03			sta	ICBAL,x
   125 4069 AD 37 41			lda	TextPtr+1
   126 406C 9D 45 03			sta	ICBAL+1,x
   127 406F 20 56 E4			jsr	ciov
   128 4072			PutLine_Error
   129 4072 60				rts
   130 					
   131 				;--------------------------------------------------------
   132 				; Set_Graphics_Mode - sets graphics mode
   133 				; takes:
   134 				; A - device handler (E, S, or V (S2))
   135 				; X - IOCB offset (IOCB channel number multiplied by 16)
   136 				; Y - mode to set
   137 				; returns:
   138 				; Y - error code (95 - too many channels open) if it fails
   139
   140 4073			SetGraphicsMode
   141 4073 20 2D 40			jsr	Find_First_IOCB		; find first free IOCB
   142 4076 C0 01			cpy	#1
   143 4078 D0 22			bne	SetGraphicsMode_Error	; no more free IOCB
   144 407A C9 56			cmp	#'V'
   145 407C F0 1F			beq	SetGraphicsMode_VBXE	; VBXE device handler is S2:, so we need special case for it :(
   146 407E 8D 01 40			sta	Temporary_Handler
   147 4081 A9 01			lda	#<Temporary_Handler
   148 4083 9D 44 03			sta	ICBAL,x
   149 4086 A9 40			lda	#>Temporary_Handler
   150 4088 9D 45 03			sta	ICBAL+1,x
   151 408B			SetGraphicsMode_Common
   152 408B 98				tya
   153 408C 9D 4B 03			sta	ICAX2,x		; mode to obtain
   154 408F A9 03			lda	#CIO_open	
   155 4091 9D 42 03			sta	iccmd,x
   156 4094 A9 0C			lda	#CIO_read|CIO_write	; for both READ and WRITE operations
   157 4096 9D 4A 03			sta	ICAX1,x
   158 4099 20 56 E4			jsr	ciov
   159 409C			SetGraphicsMode_Error
   160 409C 60				rts
   161 409D			SetGraphicsMode_VBXE
   162 409D A9 05			lda	#<VBXE_Handler
   163 409F 9D 44 03			sta	ICBAL,x
   164 40A2 A9 40			lda	#>VBXE_Handler
   165 40A4 9D 45 03			sta	ICBAL+1,x
   166 40A7 4C 8B 40			jmp	SetGraphicsMode_Common
   167 					
