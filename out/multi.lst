   144 				;		Common calls for VBXE
   145 				;--------------------------------------------------------
   146
   147 				;--------------------------------------------------------
   148 				;VBXE_Detect - detects VBXE FX core version 1.07 and above,
   149 				; and stores VBXE Base address in VBXEBase
   150 4139			VBXE_Detect
   151 4139 A9 00			lda	#0
   152 413B A2 D6			ldx	#$d6
   153 413D 8D 40 D6			sta	$d640			; make sure it isn't coincidence
   154 4140 AD 40 D6			lda	$d640
   155 4143 C9 10			cmp	#$10			; do we have major version here?
   156 4145 F0 15			beq	VBXE_Detected	; if so, then VBXE is detected
   157 4147 A9 00			lda	#0
   158 4149 E8				inx
   159 414A 8D 40 D7			sta	$d740			; no such luck, try other location
   160 414D AD 40 D7			lda	$d740
   161 4150 C9 10			cmp	#$10
   162 4152 F0 08			beq	VBXE_Detected
   163 4154 A2 00			ldx 	#0  		; not here, so not present or FX core version too low
   164 4156 86 90			stx	VBXEBase+1
   165 4158 86 8F			stx	VBXEBase
   166 415A 38				sec
   167 415B 60				rts
   168 415C			VBXE_Detected:
   169 415C 86 90			stx	VBXEBase+1
   170 415E A9 00			lda	#0
