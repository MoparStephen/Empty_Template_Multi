     4 = 0007			CIO_getdata		equ 7	;READ of binary data
     5 = 0009			CIO_puttext		equ 9	;WRITE of text line
     6 = 000B			CIO_putdata		equ 11	;WRITE of binary data
     7 = 000C			CIO_close    	equ 12	;CLOSE of IOCB channel
     8 = 000D			CIO_getstatus	equ 13	;READ of device status
