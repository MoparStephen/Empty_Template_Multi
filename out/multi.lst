   111 				;--------------------------------------------------------
   112 				;vblda	- loads accumulator with VBXE register value
   113 				;	  use:	vblda	VBXE_REGISTER
   114
   115 				vblda	.macro
   116 				.ifdef	__VBXE_AUTO__
   117 					lda	VBXEBase+1
   118 					sta	vblda_adr
   119 					lda.w	:1
   120 				vblda_adr	equ *-1
   121 				.else
   122 					lda	:1
   123 				.endif
   124 				.endm
   125
   126 				;--------------------------------------------------------
   127 				;vbsta	- stores accumulator in VBXE register
   128 				;	  use:	vbsta	VBXE_REGISTER
   129
   130 				vbsta	.macro
   131 				.ifdef	__VBXE_AUTO__
   132 					pha
   133 					lda	VBXEBase+1
   134 					sta	vbsta_adr
   135 					pla
   136 					sta.w	:1
   137 				vbsta_adr	equ *-1
   138 				.else
   139 					sta.w	:1
   140 				.endif
   141 				.endm
