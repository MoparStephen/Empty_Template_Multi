Source: bcbs.asm
     1 				; Clear 496kB (leave bottom 16kB for the SVBXE.SYS driver)
     2 				; 496x16 zoom 8x8 clear blit (this takes 2 frames)
     3 2000			BLT_CLEAR
     4 2000-2029> 00 00 00		dta $00,$00,$00						; Source address
     5 2003 00 00			dta $00,$00							; Source step y
     6 2005 00				dta $00								; Source step x
     7 2006 FF BF 07			dta $FF,$BF,$07						; Destination address
     8 2009 80 F0			dta a(-$0F80)						; Destination step y (backwards 3968 bytes) - NOTE: this equals 496 * zoom factor of 8
     9 200B FF				dta -$01							; Destination step x (backwards	1 byte)
    10 200C EF 01			dta $EF,$01							; Width-1  (495)	496 * 8 bytes wide
    11 200E 0F				dta $0F								; Height-1 (15)		 16 * 8 bytes high
    12 200F 00				dta $00								; And mask (And mask equal to 0 so clear)
    13 2010 00				dta $00								; Xor mask (will be filled with xor mask)
    14 2011 00				dta $00								; Collision and mask
    15 2012 77				dta $77								; Zoom (BLT_ZOOMY = 7, BLT_ZOOMX = 7 so 8Y*8X)
    16 2013 00				dta $00								; Pattern feature
    17 2014 00				dta $00								; Control (Mode 0 with NEXT bit Cleared)
    18
    19 				; Copy 9600 attrib bytes from $14000, placing each at every 4th dest byte from $17003
    20 				; 40 cells/row * 240 rows = 9600 bytes; dest stride 4 writes to $17003,$17007,$1700B...
    21 				; The 3 zero bytes before each data byte are left intact from BLT_SETUP_CMAP_1
    22 2015			BLT_SETUP_CMAP_1
    23 2015 00 40 01			dta $00,$40,$01						; Source address ($14000)
    24 2018 28 00			dta $28,$00							; Source step y = 40 (advance to next row: 40 cells * 1 byte)
    25 201A 01				dta $01								; Source step x (1)
    26 201B 03 70 01			dta $03,$70,$01						; Destination address ($17003)
    27 201E A0 00			dta $A0,$00							; Destination step y = 160 (advance to next row: 40 cells * 4 bytes)
    28 2020 04				dta $04								; Destination step x (4)
    29 2021 27 00			dta $27,$00							; Width-1 = 39   (40 cells/row)
    30 2023 EF				dta $EF								; Height-1 = 239 (240 rows; 40*240 = 9600)
    31 2024 FF				dta $FF								; And mask ($FF - pass-through, copies zero values too)
    32 2025 00				dta $00								; Xor mask (no inversion)
    33 2026 00				dta $00								; Collision mask
    34 2027 00				dta $00								; Zoom
    35 2028 00				dta $00								; Pattern feature
    36 2029 00				dta $00								; Control: MODE=0 (copy), NEXT=0 (last BCB)
   475 = 002A			BLT_Length	equ *-BCB_START
