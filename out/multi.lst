   169 				; LoadData - Loads file into banked memory
   170 				; bankindex - first bank number to load to
   171 				; This is slighty modified code provided by Mono (AtariArea)
   172 				; visit http://atariarea.krap.pl/forum/viewtopic.php?id=6781
   173 				; to see the original version
   174 40AA			LoadData
   175 40AA A9 01			lda #1
   176 40AC 8D 38 41			sta LoadStatus	; Indicate Failure
   177 40AF 20 2D 40			jsr	Find_First_IOCB
   178 40B2 C0 01			cpy	#1
   179 40B4 D0 77			bne	LoadData_Error
   180 40B6 A9 04			lda	#CIO_read
   181 40B8 9D 4A 03			sta	ICAX1,x
   182 40BB A9 03			lda	#CIO_open
   183 40BD 9D 42 03			sta	iccmd,x
   184 40C0 AD 33 41			lda	FileNamePtr
   185 40C3 9D 44 03			sta	ICBAL,x
   186 40C6 AD 34 41			lda	FileNamePtr+1
   187 40C9 9D 45 03			sta	ICBAL+1,x
   188 40CC AD 35 41			lda	FileNameLng
   189 40CF 9D 48 03			sta	ICBLL,x
   190 40D2 A9 00			lda	#0
   191 40D4 9D 49 03			sta	ICBLL+1,x
   192 40D7 20 56 E4			jsr	ciov
   193 40DA 30 51			bmi	LoadData_Error
   194 40DC A4 8A			ldy	BankIndex
   195 40DE			LoadData_l1
   196 40DE 98				tya
   197 40DF 09 80			ora	#0x80
   198 40E1				vbsta	VBXE_MA_BSEL
